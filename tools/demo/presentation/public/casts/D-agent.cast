[4.217102, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[2C\u001b[3AUsing\u001b[9Gthe\u001b[13Gdesign-data\u001b[25GMCP,\u001b[30Glook\u001b[35Gup\u001b[38Gthe\u001b[42Gbutton\u001b[49Gcomponent\u001b[59Gand\u001b[63Gtell\u001b[68Gme:\u001b[72G1.\u001b[75GWhat\u001b[80Gits\u001b[84Gaccessibility\u001b[98Grole\u001b[103Gand\u001b[107Gkeyboard\r\u001b[1B  intents are 2. Which states it declares 3. Which token resolves the default background color in the dark color\u001b[K\r\u001b[2C\u001b[1Bscheme. Show the answers with citations from the spec,\u001b[58Gnot\u001b[62Ga\u001b[64Gguess.\u001b[7m \u001b[101G\u001b[27m\u001b[K\r\r\n\u001b[38;2;136;136;136m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[39m\r\r\n\u001b[3G\u001b[38;2;255;193;7m\u23f5\u23f5\u001b[6Gauto\u001b[11Gmode\u001b[16Gon\u001b[38;2;153;153;153m (shift+tab\u001b[30Gto\u001b[33Gcycle)\u001b[101G\u25d0\u001b[103Gmedium\u001b[110G\u00b7\u001b[112G/effort\u001b[39m\r\r\n\u001b[69C\u001b[3A\u001b[?2026l"]
