{
  "$schema": "https://opensource.adobe.com/spectrum-design-data/schemas/v0/component.schema.json",
  "$id": "https://opensource.adobe.com/spectrum-design-data/schemas/v0/components/tag-field.json",
  "specVersion": "1.0.0-draft",
  "name": "tag-field",
  "displayName": "Tag field",
  "description": "A tag field is an input field that allows users to enter and manage tags.",
  "meta": {
    "category": "inputs",
    "documentationUrl": "https://spectrum.adobe.com/page/tag-field/"
  },
  "documentBlocks": [
    {
      "type": "purpose",
      "content": "A tag field is an input field that allows users to enter and manage tags."
    },
    {
      "type": "guideline",
      "content": "Tag field is an input component for adding and editing multiple tags. It includes standard field label and error options, and is used to capture grouped keywords or descriptors. Tags can be added directly in the field and displayed inline for editing or removal."
    },
    {
      "type": "guideline",
      "content": "The label of the tag field can be hidden if the context for the tags is sufficient without the title — for example, when the page title or section title applies to the group of tags."
    },
    {
      "type": "guideline",
      "content": "A tag field in a disabled state indicates that it exists but is not available in that context. This state helps maintain layout continuity and signals that tagging may become available later."
    },
    {
      "type": "guideline",
      "content": "Tag groups within a tag field can include a keyword, icon, thumbnail or avatar. Icons, thumbnails and avatars should also include a keyword."
    },
    {
      "type": "guideline",
      "content": "Tag fields come in three different sizes: small, medium, and large. The medium size is the default and most frequently used option. Use the other sizes sparingly; they should be used to create a hierarchy of importance within the page."
    },
    {
      "type": "guideline",
      "content": "A flyout/menu appears when the user starts typing to suggest tags that are supported or have already been entered previously."
    },
    {
      "type": "guideline",
      "content": "Sometimes tag field can be additive, meaning new tags may be added from this particular tag field. They can also be restricted to only allowing tags that already exist in the system"
    },
    {
      "type": "guideline",
      "content": "When there are more tags than fit in the horizontal space, tags wrap to another line."
    },
    {
      "type": "guideline",
      "content": "If the order of tags within the group matters, the user must be able to click or use keyboard focus between tags to add more."
    },
    {
      "type": "guideline",
      "content": "If there is space in an experience for the field to grow with the tags, such as at the bottom of a page or dialog, you can use the multi-line option."
    },
    {
      "type": "guideline",
      "content": "If the tag field is located at the top of a header or otherwise constrained space, it is better to use a non-multi-line tag field."
    },
    {
      "type": "guideline",
      "content": "The default option should be a standard text field with tags displayed below it. You may use a tag field if space is limited, especially when using a single-line tag field. This allows all fields to stay contained within a defined area."
    }
  ],
  "options": {
    "size": {
      "type": "string",
      "default": "m",
      "values": [{ "value": "s" }, { "value": "m" }, { "value": "l" }]
    },
    "style": {
      "type": "string",
      "default": "keyword",
      "values": [
        { "value": "keyword" },
        { "value": "icon" },
        { "value": "thumbnail" },
        { "value": "avatar" }
      ]
    },
    "isDisabled": { "type": "boolean", "default": false },
    "hideLabel": { "type": "boolean", "default": false }
  },
