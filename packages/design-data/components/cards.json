{
  "$schema": "https://opensource.adobe.com/spectrum-design-data/schemas/v0/component.schema.json",
  "$id": "https://opensource.adobe.com/spectrum-design-data/schemas/v0/components/cards.json",
  "specVersion": "1.0.0-draft",
  "name": "cards",
  "displayName": "Cards",
  "description": "Cards group related content into distinct layouts depending on context.",
  "meta": {
    "category": "containers",
    "documentationUrl": "https://spectrum.adobe.com/page/cards/"
  },
  "documentBlocks": [
    {
      "type": "purpose",
      "content": "Cards group related content into distinct layouts depending on context."
    },
    {
      "type": "guideline",
      "content": "Cards group related content and actions into flexible containers for browsing. They preview key information and reveal more detail on interaction."
    },
    {
      "type": "guideline",
      "content": "Card preview areas have a maximum image height aspect ratio of 3:4, and a minimum height aspect ratio of of 4:1."
    },
    {
      "type": "guideline",
      "content": "If the card has a fixed height, such as in a tile grid, long titles will be truncated. Use short titles to avoid this. In layouts with variable height, like a waterfall grid, titles will wrap to fit."
    },
    {
      "type": "guideline",
      "content": "Cards, by definition, should have some form of interaction such as viewing, editing, purchasing, etc. Some actions are exposed in buttons, and others simply occur by clicking the card."
    },
    {
      "type": "guideline",
      "content": "If a card only has an ability to be opened or viewed in more detail, do not include a button. Clicking anywhere on the card should perform that action."
    },
    {
      "type": "guideline",
      "content": "If a card has other interactive elements such as a hidden actions menu or an avatar, but no buttons, the whole card (outside of those elements) should be clickable."
    },
    {
      "type": "guideline",
      "content": "If there’s only one action (that’s not opening or viewing the card), use a button to communicate that action. If there are two or more available actions, and one of those actions is to open or view the card, use a button to communicate “View” or “Open,” instead of relying on clicking on the card."
    },
    {
      "type": "guideline",
      "content": "If a standard card has a footer with a button, only the button is clickable. If a card has a preview, clicking the preview will open that card. When a preview is purely decorative, it is not clickable."
    },
    {
      "type": "guideline",
      "content": "When a group of cards are loading, they follow the ghost loading convention. There are 5 phases for ghost loading:"
    },
    {
      "type": "guideline",
      "content": "Cards are meant to just show a taste of the available information. Don’t overload cards with more information than necessary."
    },
    {
      "type": "guideline",
      "content": "Only standard cards can have a footer, and buttons can only appear inside a footer."
    },
    {
      "type": "guideline",
      "content": "Individual cards are not aligned to individual columns in the page's responsive column grid. Instead, groups of cards are aligned to the column grid in a layout region."
    },
    {
      "type": "guideline",
      "content": "If the preview is a video clip or other moving item, do not automatically play the clip or motion. Save the movement for either when a user hovers on the card or when they click on a play button."
    }
  ],
  "options": {
    "variant": {
      "type": "string",
      "default": "asset",
      "description": "Determines which card layout variant is used.",
      "values": [
        { "value": "asset" },
        { "value": "collection" },
        { "value": "flex" },
        { "value": "gallery" },
        { "value": "horizontal" },
        { "value": "product" }
      ]
    }
  },
