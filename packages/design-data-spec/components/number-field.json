{
  "$schema": "https://opensource.adobe.com/spectrum-design-data/schemas/v0/component.schema.json",
  "$id": "https://opensource.adobe.com/spectrum-design-data/schemas/v0/components/number-field.json",
  "specVersion": "1.0.0-draft",
  "name": "number-field",
  "displayName": "Number field",
  "description": "Number fields allow users to enter a numeric value, with optional increment and decrement buttons.",
  "meta": {
    "category": "inputs",
    "documentationUrl": "https://spectrum.adobe.com/page/number-field/"
  },
  "options": {
    "label": {
      "type": "string"
    },
    "size": {
      "type": "string",
      "default": "m",
      "values": [
        {
          "value": "s"
        },
        {
          "value": "m"
        },
        {
          "value": "l"
        },
        {
          "value": "xl"
        }
      ]
    },
    "labelPosition": {
      "type": "string",
      "default": "top",
      "values": [
        {
          "value": "top"
        },
        {
          "value": "side"
        }
      ]
    },
    "hideLabel": {
      "type": "boolean",
      "default": false
    },
    "isDisabled": {
      "type": "boolean",
      "default": false
    },
    "isError": {
      "type": "boolean",
      "default": false
    },
    "isRequired": {
      "type": "boolean",
      "default": false
    },
    "necessityIndicator": {
      "type": "string",
      "default": "icon",
      "values": [
        {
          "value": "text"
        },
        {
          "value": "icon"
        }
      ]
    },
    "hideStepper": {
      "type": "boolean",
      "default": false,
      "description": "If true, hides in-field increment and decrement buttons (stepper)."
    }
  },
  "states": [
    {
      "name": "hover",
      "trigger": "interaction"
    },
    {
      "name": "focus-+-hover",
      "trigger": "prop"
    },
    {
      "name": "focus-+-not-hover",
      "trigger": "prop"
    }
  ],
  "lifecycle": {
    "introduced": "1.0.0-draft"
  },
