      "context": "Size"
    },
    {
      "token": "thumbnail-size-500",
      "context": "Size"
    },
    {
      "token": "thumbnail-size-600",
      "context": "Size"
    },
    {
      "token": "thumbnail-size-700",
      "context": "Size"
