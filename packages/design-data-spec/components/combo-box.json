        {
          "value": "s"
        },
        {
          "value": "m"
        },
        {
          "value": "l"
        },
        {
          "value": "xl"
        }
      ]
    },
    "isRequired": {
      "type": "boolean",
      "default": false
    },
    "necessityIndicator": {
      "type": "string",
      "default": "icon",
      "values": [
        {
          "value": "text"
        },
        {
          "value": "icon"
        }
      ]
    },
    "hasAutocomplete": {
      "type": "boolean",
      "default": false
    },
    "menuTrigger": {
      "type": "string",
      "default": "input",
      "values": [
        {
          "value": "input"
        },
        {
          "value": "focus"
        },
        {
          "value": "manual"
        }
      ]
    },
    "isError": {
      "type": "boolean",
      "default": false
    },
    "isDisabled": {
      "type": "boolean",
      "default": false
    },
    "isReadOnly": {
      "type": "boolean",
      "default": false
    },
    "description": {
      "type": "string"
    },
    "errorMessage": {
      "type": "string"
    }
  },
  "states": [
