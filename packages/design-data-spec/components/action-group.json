{
  "$schema": "https://opensource.adobe.com/spectrum-design-data/schemas/v0/component.schema.json",
  "$id": "https://opensource.adobe.com/spectrum-design-data/schemas/v0/components/action-group.json",
  "specVersion": "1.0.0-draft",
  "name": "action-group",
  "displayName": "Action group",
  "description": "An action group is a grouping of action buttons that are related to each other.",
  "meta": {
    "category": "actions",
    "documentationUrl": "https://spectrum.adobe.com/page/action-group/"
  },
  "options": {
    "orientation": {
      "type": "string",
      "default": "horizontal",
      "values": [
        {
          "value": "horizontal"
        },
        {
          "value": "vertical"
        }
      ]
    },
    "size": {
      "type": "string",
      "default": "m",
      "values": [
        {
          "value": "s"
        },
        {
          "value": "m"
        },
        {
          "value": "l"
        },
        {
          "value": "xl"
        }
      ]
    },
    "density": {
      "type": "string",
      "default": "regular",
      "values": [
        {
          "value": "regular"
        },
        {
          "value": "compact"
        }
      ]
    },
    "isJustified": {
      "type": "boolean",
      "default": false
    },
    "isQuiet": {
      "type": "boolean",
      "default": false
    },
    "isEmphasized": {
      "type": "boolean",
      "default": false
    },
    "enableSelection": {
      "type": "boolean",
      "default": false
    },
    "selectionMode": {
      "type": "string",
      "default": "single",
      "description": "Only applicable if selection is enabled",
      "values": [
        {
          "value": "single"
        },
        {
          "value": "multiple"
        }
      ]
    },
    "allowsEmptySelection": {
      "type": "boolean",
      "default": false,
      "description": "Only applicable if selection is enabled"
    },
    "overflowMode": {
      "type": "string",
      "default": "wrap",
      "values": [
        {
          "value": "wrap"
        },
        {
          "value": "collapse"
        }
      ]
    },
    "isDisabled": {
      "type": "boolean",
      "default": false
    }
  },
  "lifecycle": {
    "introduced": "1.0.0-draft"
  },
  "tokenBindings": [
    {
      "token": "spacing-75",
      "context": "Spacing (horizontal, regular)"
    },
    {
      "token": "spacing-100",
      "context": "Spacing (horizontal, regular)"
    },
    {
      "token": "spacing-50",
      "context": "Spacing (horizontal, compact)"
    }
  ],
  "accessibility": {
    "intents": ["trigger"],
    "focusable": false,
    "wcag": [
      {
        "criterion": "2.1.1",
        "level": "A",
        "title": "Keyboard"
      }
    ]
  }
}
