{
  "$schema": "https://opensource.adobe.com/spectrum-design-data/schemas/v0/component.schema.json",
  "$id": "https://opensource.adobe.com/spectrum-design-data/schemas/v0/components/picker.json",
  "specVersion": "1.0.0-draft",
  "name": "picker",
  "displayName": "Picker",
  "description": "Pickers (sometimes known as \"dropdowns\" or \"selects\") allow users to choose from a list of options in a limited space. The list of options can change based on the context.",
  "meta": {
    "category": "inputs",
    "documentationUrl": "https://spectrum.adobe.com/page/picker/"
  },
  "options": {
    "label": {
      "type": "string"
    },
    "labelPosition": {
      "type": "string",
      "default": "top",
      "values": [
        {
          "value": "top"
        },
        {
          "value": "side"
        }
      ]
    },
    "placeholder": {
      "type": "string"
    },
    "value": {
      "type": "string"
    },
    "width": {
      "type": "number",
      "description": "Not applicable to quiet picker."
    },
    "size": {
      "type": "string",
      "default": "m",
      "values": [
        {
          "value": "s"
        },
        {
          "value": "m"
        },
        {
          "value": "l"
        },
        {
          "value": "xl"
        }
      ]
    },
    "isQuiet": {
      "type": "boolean",
      "default": false
    },
    "necessityIndicator": {
      "type": "string",
      "default": "icon",
      "values": [
        {
          "value": "text"
        },
        {
          "value": "icon"
        }
      ]
    },
    "isRequired": {
      "type": "boolean",
      "default": false
    },
    "menuContainer": {
      "type": "string",
      "default": "popover",
      "values": [
        {
          "value": "popover"
        },
        {
          "value": "tray"
        }
      ]
    },
    "isDisabled": {
      "type": "boolean",
      "default": false
    },
    "isError": {
      "type": "boolean",
      "default": false
    },
    "description": {
      "type": "string",
      "default": null
    },
    "errorMessage": {
      "type": "string",
      "default": null
    }
  },
  "states": [
    {
      "name": "hover",
      "trigger": "interaction"
    },
    {
      "name": "focus-+-hover",
      "trigger": "prop"
    },
    {
      "name": "focus-+-not-hover",
      "trigger": "prop"
    },
    {
      "name": "keyboard-focus",
      "trigger": "interaction"
    }
  ],
  "lifecycle": {
    "introduced": "1.0.0-draft"
  },
